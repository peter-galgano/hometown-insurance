---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<main class="font-sans text-gray-900">
		<nav class="bg-[#1a1a2e] flex items-center justify-between px-6 md:px-12 py-4 text-white">
			<span class="text-lg font-bold">Hometown Insurance</span>
			<ul class="flex gap-6 list-none m-0 p-0 text-sm">
				<li><a href="/" class="text-white hover:opacity-75 no-underline">Home</a></li>
				<li><a href="/about" class="text-white hover:opacity-75 no-underline">About</a></li>
				<li><a href="/services" class="text-white hover:opacity-75 no-underline">Services</a></li>
				<li><a href="/contact" class="text-white hover:opacity-75 no-underline">Contact</a></li>
			</ul>
		</nav>

		<section class="py-20 px-8 bg-linear-to-br from-[#1a1a2e] via-[#16213e] to-[#0f3460] text-white text-center">
			<h1 class="text-4xl md:text-5xl font-bold mb-4">About Us</h1>
			<p class="text-base md:text-xl opacity-85">Get to know Hometown Insurance Agency</p>
		</section>

		<section class="py-20 px-8 max-w-3xl mx-auto">
			<h2 class="text-3xl font-bold mb-6">Our Story</h2>
			<p class="text-gray-600 leading-relaxed mb-6">
				Founded in Bohemia, NY, Hometown Insurance Agency was built on a simple belief: insurance should be personal. As members of the community we serve, we understand the unique needs of our neighbors and are committed to providing coverage that truly fits.
			</p>
			<p class="text-gray-600 leading-relaxed mb-6">
				We are dedicated to serving the local community with personalized insurance solutions. Whether you're looking for auto, home, or life insurance, our experienced team takes the time to understand your situation and recommend the right coverage at the right price.
			</p>
			<p class="text-gray-600 leading-relaxed">
				At Hometown Insurance, you're not just a policy number — you're a neighbor. We pride ourselves on building lasting relationships and being there when it matters most.
			</p>
		</section>
	</main>

	<footer class="bg-[#1a1a2e] text-white py-10 px-8 text-center">
		<p class="text-lg font-semibold mb-2">Hometown Insurance Agency</p>
		<p class="text-sm opacity-75 mb-1">5 Orville Drive, Suite 400, Bohemia, NY 11716</p>
		<p class="text-sm opacity-60">&copy; {new Date().getFullYear()} Hometown Insurance Agency. All rights reserved.</p>
	</footer>
</Layout>
