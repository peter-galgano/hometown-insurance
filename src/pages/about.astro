    <style>
        .section-padding { padding: 100px 0; }
        .mission-area { background: #fff; padding-bottom: 0; }
        .mission-box { border-left: 6px solid var(--primary-red); padding-left: 30px; margin-bottom: 60px; }
        .mission-box h2 { font-size: 42px; margin-bottom: 15px; min-height: 1.2em; }
        .mission-description { font-size: 20px; color: var(--text-gray); max-width: 900px; margin-top: 20px; }
        .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; margin-bottom: 60px; }
        .about-text h2 { font-size: 38px; margin-bottom: 25px; line-height: 1.2; }
        .about-img { width: 100%; border-radius: 12px; box-shadow: 0 20px 40px rgba(0,0,0,0.1); }

        .team-section { background: var(--bg-light); padding: 50px 0 100px 0; }
        .team-accordion { margin-top: 40px; }
        .team-group { margin-bottom: 15px; background: #fff; border-radius: 8px; overflow: hidden; border: 1px solid #e2e8f0; }
        .team-header { padding: 25px; cursor: pointer; display: flex; justify-content: space-between; align-items: center; background: #fff; transition: background 0.2s; }
        .team-header:hover { background: #fafafa; }
        .team-header h3 { font-size: 28px; margin: 0; color: var(--dark-blue); }
        .team-header i { color: var(--primary-red); transition: transform 0.3s; }
        .team-content { max-height: 0; overflow: hidden; transition: max-height 0.5s ease-out; padding: 0 25px; }
        .team-group.active .team-content { max-height: 4000px; padding: 30px 25px; }
        .team-group.active .team-header i { transform: rotate(180deg); }

        .team-grid-exec { display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px; }
        .team-grid-small { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }

        .team-card { background: var(--bg-light); border-radius: 12px; overflow: hidden; height: 100%; border: 1px solid #eee; }
        .member-img { height: 280px; background: #cbd5e1; display: flex; align-items: center; justify-content: center; font-size: 40px; color: #94a3b8; }
        .team-card-small .member-img { height: 200px; font-size: 30px; }
        .member-info { padding: 20px; }
        .member-info h4 { font-size: 20px; margin-bottom: 5px; color: var(--dark-blue); }
        .member-info p { font-size: 14px; color: var(--primary-red); font-weight: 700; margin-bottom: 10px; text-transform: uppercase; line-height: 1.3; }
        .member-contact { font-size: 13px; color: var(--text-gray); border-top: 1px solid #ddd; padding-top: 10px; }

        .product-selector { text-align: center; padding: 60px 0 100px 0; background: white; }

        @media (max-width: 992px) {
            .team-grid-exec, .team-grid-small { grid-template-columns: 1fr 1fr; }
            .about-grid { grid-template-columns: 1fr; }
        }
        @media (max-width: 600px) {
            .team-grid-exec, .team-grid-small { grid-template-columns: 1fr; }
        }
    </style>

    <script is:inline>
        const phrases = ["We work for you", "We save money for you", "We protect you and your family"];
        const typingElement = document.getElementById("typing-text");
        let phraseIndex = 0;
        let charIndex = 0;
        const typingSpeed = 100;
        const displayTime = 3000;

        function typePhrase() {
            if (charIndex < phrases[phraseIndex].length) {
                typingElement.style.opacity = "1";
                typingElement.textContent += phrases[phraseIndex].charAt(charIndex);
                charIndex++;
                setTimeout(typePhrase, typingSpeed);
            } else {
                setTimeout(fadeOutPhrase, displayTime);
            }
        }

        function fadeOutPhrase() {
            typingElement.style.opacity = "0";
            setTimeout(() => {
                typingElement.textContent = "";
                charIndex = 0;
                phraseIndex = (phraseIndex + 1) % phrases.length;
                typePhrase();
            }, 1000);
        }

        typePhrase();

        document.querySelectorAll('.team-header').forEach(header => {
            header.addEventListener('click', () => {
                const group = header.parentElement;
                if (group.classList.contains('active')) {
                    group.classList.remove('active');
                } else {
                    group.classList.add('active');
                }
            });
        });
    </script>

