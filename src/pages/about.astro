    <style>
        .section-padding { padding: 100px 0; }
        .mission-area { background: #fff; padding-bottom: 0; }
        .mission-box { border-left: 6px solid var(--primary-red); padding-left: 30px; margin-bottom: 60px; }
        .mission-box h2 { font-size: 42px; margin-bottom: 15px; min-height: 1.2em; }
        .mission-description { font-size: 20px; color: var(--text-gray); max-width: 900px; margin-top: 20px; }
        .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; margin-bottom: 60px; }
        .about-text h2 { font-size: 38px; margin-bottom: 25px; line-height: 1.2; }
        .about-img { width: 100%; border-radius: 12px; box-shadow: 0 20px 40px rgba(0,0,0,0.1); }

        .team-section { background: var(--bg-light); padding: 50px 0 100px 0; }

        .team-department { margin-bottom: 40px; }
        .team-department h3 { font-size: 28px; color: var(--dark-blue); padding-bottom: 12px; border-bottom: 3px solid var(--primary-red); margin-bottom: 25px; }
        .team-grid-flat { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
        .team-card-flat { background: #fff; border: 1px solid #e2e8f0; border-radius: 10px; padding: 20px; }
        .team-card-flat h4 { font-size: 18px; color: var(--dark-blue); margin-bottom: 8px; }
        .team-card-flat .team-title { color: var(--primary-red); font-weight: 700; text-transform: uppercase; font-size: 13px; letter-spacing: 0.5px; margin-bottom: 8px; }
        .team-card-flat .team-license { color: #64748b; font-size: 13px; }

        .product-selector { text-align: center; padding: 60px 0 100px 0; background: white; }

        @media (max-width: 992px) {
            .team-grid-flat { grid-template-columns: repeat(2, 1fr); }
            .about-grid { grid-template-columns: 1fr; }
        }
        @media (max-width: 576px) {
            .team-grid-flat { grid-template-columns: 1fr; }
        }
    </style>

    <script is:inline>
        const phrases = ["We work for you", "We save money for you", "We protect you and your family"];
        const typingElement = document.getElementById("typing-text");
        let phraseIndex = 0;
        let charIndex = 0;
        const typingSpeed = 100;
        const displayTime = 3000;

        function typePhrase() {
            if (charIndex < phrases[phraseIndex].length) {
                typingElement.style.opacity = "1";
                typingElement.textContent += phrases[phraseIndex].charAt(charIndex);
                charIndex++;
                setTimeout(typePhrase, typingSpeed);
            } else {
                setTimeout(fadeOutPhrase, displayTime);
            }
        }

        function fadeOutPhrase() {
            typingElement.style.opacity = "0";
            setTimeout(() => {
                typingElement.textContent = "";
                charIndex = 0;
                phraseIndex = (phraseIndex + 1) % phrases.length;
                typePhrase();
            }, 1000);
        }

        typePhrase();


    </script>

