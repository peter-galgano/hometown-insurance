---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
	<main class="font-sans text-gray-900">
		<Nav overlay />
		<section class="flex flex-col items-center justify-center min-h-screen text-center px-8 bg-linear-to-br from-[#1a1a2e] via-[#16213e] to-[#0f3460] text-white">
			<h1 class="text-4xl md:text-5xl font-bold mb-4 leading-tight">Protecting What Matters Most</h1>
			<p class="text-base md:text-xl opacity-85">Your local insurance agency in Bohemia, NY</p>
			<a href="/contact" class="mt-8 inline-block bg-white text-gray-900 font-semibold px-8 py-3 rounded-lg no-underline hover:bg-gray-100 transition-colors">Get a Free Quote</a>
		</section>

		<section class="py-20 px-8 bg-gray-50">
			<h2 class="text-3xl font-bold text-center mb-12">Our Services</h2>
			<div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8">
				<div class="bg-white rounded-xl shadow p-8 text-center">
					<span class="text-5xl block mb-4">🚗</span>
					<h3 class="text-xl font-semibold mb-2">Auto Insurance</h3>
					<p class="text-gray-600">Comprehensive coverage to keep you protected on the road, from liability to collision and beyond.</p>
				</div>
				<div class="bg-white rounded-xl shadow p-8 text-center">
					<span class="text-5xl block mb-4">🏠</span>
					<h3 class="text-xl font-semibold mb-2">Home Insurance</h3>
					<p class="text-gray-600">Safeguard your home and belongings against unexpected events with reliable homeowners coverage.</p>
				</div>
				<div class="bg-white rounded-xl shadow p-8 text-center">
					<span class="text-5xl block mb-4">❤️</span>
					<h3 class="text-xl font-semibold mb-2">Life Insurance</h3>
					<p class="text-gray-600">Secure your family's future with flexible life insurance plans tailored to your needs.</p>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>
