---
import BaseLayout from '../layouts/BaseLayout.astro';
import allPosts from '../data/posts.json';

const recentPosts = allPosts.slice(0, 3);
---

<BaseLayout title="Hometown Insurance Agency">
    <a href="#" class="btn btn-red btn-pulse openQuoteTrigger" slot="quote-button">Get a Quote</a>

    <!-- Quote Modal -->
    <div class="modal-overlay" id="quoteModal">
        <div class="modal-content quote-form-modal">
            <span class="close-modal" id="closeQuoteModal">&times;</span>
            <div class="form-header">
                <h2>Get Your Personal Quote</h2>
                <p>Tell us a bit about your needs and we'll handle the rest.</p>
            </div>
            <form id="homeQuoteForm">
                <div class="form-group"><label>Full Name <span class="req">*</span></label><input type="text" name="full_name" placeholder="John Doe" required></div>
                <div class="form-row">
                    <div class="form-group"><label>Email Address <span class="req">*</span></label><input type="email" name="email" placeholder="john@example.com" required></div>
                    <div class="form-group"><label>Phone Number <span class="req">*</span></label><input type="tel" name="phone" placeholder="631-555-0100" required></div>
                </div>
                <div class="form-group">
                    <label>Insurance type? <span class="req">*</span></label>
                    <select id="homeInsuranceType" name="insurance_type" required>
                        <option value="" disabled selected>Select an option...</option>
                        <option>Personal Protection (Home/Auto)</option>
                        <option>Business & Commercial</option>
                        <option>Firefighter & EMS Services</option>
                        <option>Life & Health</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
                <div class="form-group" id="homeOtherInsuranceDiv" style="display: none; margin-top: -10px;">
                    <label>Please specify insurance type: <span class="req">*</span></label>
                    <input type="text" id="homeOtherInsuranceInput" name="other_insurance" placeholder="Enter coverage type...">
                </div>
                <div class="form-group">
                    <label>Preferred way for us to reach you? <span class="req">*</span></label>
                    <div class="radio-group">
                        <label class="radio-label"><input type="radio" name="contact_method" value="Email" checked> Email</label>
                        <label class="radio-label"><input type="radio" name="contact_method" value="Callback"> Give me a callback</label>
                    </div>
                </div>
                <div id="homeCallbackOptions" style="display: none; border-top: 1px solid #eee; padding-top: 15px; margin-top: 5px;">
                    <div class="form-row">
                        <div class="form-group"><label>Preferred Day <span class="req">*</span></label><select name="callback_day" required><option>Monday</option><option>Tuesday</option><option>Wednesday</option><option>Thursday</option><option>Friday</option></select></div>
                        <div class="form-group"><label>Preferred Time <span class="req">*</span></label><select name="callback_time" required><option>Morning (9am - 12pm)</option><option>Afternoon (12pm - 5pm)</option><option>Evening (After 5pm)</option></select></div>
                    </div>
                </div>
                <div class="form-group">
                    <label>How did you hear about us? <span class="req">*</span></label>
                    <select id="homeHearAbout" name="hear_about" required>
                        <option value="" disabled selected>Please select...</option>
                        <option>Google Search</option>
                        <option>Facebook / Instagram</option>
                        <option>Friend or Family Member</option>
                        <option>Mailing / Flyer</option>
                        <option>Local Event</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
                <div class="form-group" id="homeHearOtherDiv" style="display: none; margin-top: -10px;">
                    <label>Please specify how you heard about us: <span class="req">*</span></label>
                    <input type="text" id="homeHearOtherInput" name="hear_other" placeholder="Tell us how you found us...">
                </div>
                <div class="form-group">
                    <label>Promo Code (if any)</label>
                    <input type="text" name="promo_code" placeholder="Enter promo code">
                </div>
                <div class="form-group">
                    <label>Add a message (optional)</label>
                    <textarea name="message" rows="2" placeholder="Tell us more about your specific needs..."></textarea>
                </div>
                <button type="submit" class="btn btn-red btn-pulse" style="width: 100%; margin-top: 10px;">Send Quote Request</button>
            </form>
            <p id="homeQuoteFormMsg" style="display:none; margin-top:10px; font-weight:700; text-align:center;"></p>
        </div>
    </div>

    <!-- Hero Section -->
    <div class="hero-wrapper-index">
        <section class="container hero-index">
            <div class="hero-content">
                <p class="hero-label"><i class="fa-solid fa-shield-halved"></i> PROTECTION SINCE 1979</p>
                <h1>Insurance coverage for what matters most</h1>
                <p>At Hometown Insurance Agency, our mission is to empower business leaders, families, and communities with trusted guidance and ironclad insurance protection so they can build, grow, and protect their future with confidence.</p>
                <div>
                    <a href="#" class="btn btn-red btn-pulse openQuoteTrigger">Get a Quote</a>
                    <a href="#insurance-built" class="btn btn-white" style="margin-left:15px;">View Our Products</a>
                </div>
            </div>
            <div class="hero-img">
                <button class="carousel-control prev" id="prevSlide"><i class="fa-solid fa-chevron-left"></i></button>
                <div class="carousel-track" id="heroCarousel">
                    <img src="https://images.unsplash.com/photo-1556911220-e15b29be8c8f?auto=format&fit=crop&w=800&q=80" class="carousel-slide active" alt="Home protection">
                    <img src="https://static-asset.amac.us/wp-content/uploads/2026/02/05112417/Couple-montage.jpg" class="carousel-slide" alt="Couple">
                    <img src="https://static-asset.amac.us/wp-content/uploads/2026/02/05112151/Medical-montage.jpg" class="carousel-slide" alt="Medical">
                    <img src="/images/firefighter-new.jpg" class="carousel-slide" alt="Firefighters">
                    <img src="https://static-asset.amac.us/wp-content/uploads/2026/02/05112147/Family-montage.jpg" class="carousel-slide" alt="Family">
                    <img src="https://static-asset.amac.us/wp-content/uploads/2026/02/05112144/Driving-montage.jpg" class="carousel-slide" alt="Driving">
                    <img src="https://static-asset.amac.us/wp-content/uploads/2026/02/05112142/Cyber-montage.jpg" class="carousel-slide" alt="Cyber">
                    <img src="https://static-asset.amac.us/wp-content/uploads/2026/02/05112140/Business-montage.jpg" class="carousel-slide" alt="Business">
                    <img src="/images/ems-new.jpg" class="carousel-slide" alt="EMS Services">
                </div>
                <button class="carousel-control next" id="nextSlide"><i class="fa-solid fa-chevron-right"></i></button>
            </div>
        </section>
    </div>

