---
import BaseLayout from '../layouts/BaseLayout.astro';
import allPosts from '../data/posts.json';

const recentPosts = allPosts.slice(0, 3);
---

<BaseLayout title="Hometown Insurance Agency Prototype">
    <a href="#" class="btn btn-red btn-pulse openQuoteTrigger" slot="quote-button">Get a Quote</a>

    <!-- Quote Modal -->
    <div class="modal-overlay" id="quoteModal">
        <div class="modal-content quote-form-modal">
            <span class="close-modal" id="closeQuoteModal">&times;</span>
            <div class="form-header">
                <h2>Get Your Personal Quote</h2>
                <p>Tell us a bit about your needs and we'll handle the rest.</p>
            </div>
            <form id="quoteForm">
                <div class="form-group"><label>Full Name</label><input type="text" placeholder="John Doe" required></div>
                <div class="form-row">
                    <div class="form-group"><label>Email Address</label><input type="email" placeholder="john@example.com" required></div>
                    <div class="form-group"><label>Phone Number</label><input type="tel" placeholder="631-555-0100" required></div>
                </div>
                <div class="form-group">
                    <label>Insurance type?</label>
                    <select id="insuranceType" required>
                        <option value="" disabled selected>Select an option...</option>
                        <option>Personal Protection (Home/Auto)</option>
                        <option>Business & Commercial</option>
                        <option>Firefighter & EMS Services</option>
                        <option>Life & Health</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
                <div class="form-group" id="otherInsuranceDiv" style="display: none; margin-top: -10px;">
                    <label>Please specify insurance type:</label>
                    <input type="text" id="otherInsuranceInput" placeholder="Enter coverage type...">
                </div>
                <div class="form-group">
                    <label>Preferred way for us to reach you?</label>
                    <div class="radio-group">
                        <label class="radio-label"><input type="radio" name="contact_method" value="Email" checked> Email</label>
                        <label class="radio-label"><input type="radio" name="contact_method" value="Callback"> Give me a callback</label>
                    </div>
                </div>
                <div id="callbackOptions" style="display: none; border-top: 1px solid #eee; padding-top: 15px; margin-top: 5px;">
                    <div class="form-row">
                        <div class="form-group"><label>Preferred Day</label><select><option>Monday</option><option>Tuesday</option><option>Wednesday</option><option>Thursday</option><option>Friday</option></select></div>
                        <div class="form-group"><label>Preferred Time</label><select><option>Morning (9am - 12pm)</option><option>Afternoon (12pm - 5pm)</option><option>Evening (After 5pm)</option></select></div>
                    </div>
                </div>
                <div class="form-group">
                    <label>Add a message (optional)</label>
                    <textarea rows="2" placeholder="Tell us more about your specific needs..."></textarea>
                </div>
                <button type="submit" class="btn btn-red btn-pulse" style="width: 100%; margin-top: 10px;">Send Quote Request</button>
            </form>
        </div>
    </div>

    <!-- Hero Section -->
    <div class="hero-wrapper-index">
        <section class="container hero-index">
            <div class="hero-content">
                <p class="hero-label"><i class="fa-solid fa-shield-halved"></i> PROTECTION SINCE 1979</p>
                <h1>Insurance coverage for what matters most</h1>
                <p>At Hometown Insurance Agency, our mission is to empower business leaders, families, and communities with trusted guidance and ironclad insurance protection so they can build, grow, and protect their future with confidence.</p>
                <div>
                    <a href="#" class="btn btn-red btn-pulse openQuoteTrigger">Get a Quote</a>
                    <a href="#insurance-built" class="btn btn-white" style="margin-left:15px;">View Our Products</a>
                </div>
            </div>
            <div class="hero-img">
                <button class="carousel-control prev" id="prevSlide"><i class="fa-solid fa-chevron-left"></i></button>
                <div class="carousel-track" id="heroCarousel">
                    <img src="https://images.unsplash.com/photo-1556911220-e15b29be8c8f?auto=format&fit=crop&w=800&q=80" class="carousel-slide active" alt="Home protection">
                    <img src="https://static-asset.amac.us/wp-content/uploads/2026/02/05112417/Couple-montage.jpg" class="carousel-slide" alt="Couple">
                    <img src="https://static-asset.amac.us/wp-content/uploads/2026/02/05112151/Medical-montage.jpg" class="carousel-slide" alt="Medical">
                    <img src="https://static-asset.amac.us/wp-content/uploads/2026/02/05112149/Firefighters-montage.jpg" class="carousel-slide" alt="Firefighters">
                    <img src="https://static-asset.amac.us/wp-content/uploads/2026/02/05112147/Family-montage.jpg" class="carousel-slide" alt="Family">
                    <img src="https://static-asset.amac.us/wp-content/uploads/2026/02/05112144/Driving-montage.jpg" class="carousel-slide" alt="Driving">
                    <img src="https://static-asset.amac.us/wp-content/uploads/2026/02/05112142/Cyber-montage.jpg" class="carousel-slide" alt="Cyber">
                    <img src="https://static-asset.amac.us/wp-content/uploads/2026/02/05112140/Business-montage.jpg" class="carousel-slide" alt="Business">
                    <img src="https://static-asset.amac.us/wp-content/uploads/2026/02/05102933/firefighters.jpg" class="carousel-slide" alt="Firefighters">
                </div>
                <button class="carousel-control next" id="nextSlide"><i class="fa-solid fa-chevron-right"></i></button>
            </div>
        </section>
    </div>

    <!-- Reviews Bar -->
    <div class="reviews-bar" id="reviews-section">
        <div class="container">
            <div class="marquee-wrapper">
                <div class="reviews-marquee-track">
                    <div class="review-card">
                        <div class="stars"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div>
                        <span class="category">Commercial</span>
                        <p class="review-text">"Reasonable price. All the people here at Hometown have been very courteous and accommodating..."</p>
                        <p class="author">John M</p>
                    </div>
                    <div class="review-card">
                        <div class="stars"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div>
                        <span class="category">Commercial</span>
                        <p class="review-text">"I've had the pleasure of insuring my businesses and properties with Hometown Insurance for many years..."</p>
                        <p class="author">K M</p>
                    </div>
                    <div class="review-card">
                        <div class="stars"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div>
                        <span class="category">Personal</span>
                        <p class="review-text">"I have been with Hometown Insurance Agency since 1979, when I bought my first car. ..."</p>
                        <p class="author">Mario Martins</p>
                    </div>
                    <div class="review-card">
                        <div class="stars"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div>
                        <span class="category">Personal</span>
                        <p class="review-text">"I couldn't be happier with the team at Hometown. They treat you like family!! Yesterday..."</p>
                        <p class="author">Laurie Kleinhenz</p>
                    </div>
                    <!-- Duplicated for seamless scroll -->
                    <div class="review-card">
                        <div class="stars"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div>
                        <span class="category">Commercial</span>
                        <p class="review-text">"Reasonable price. All the people here at Hometown have been very courteous and accommodating..."</p>
                        <p class="author">John M</p>
                    </div>
                    <div class="review-card">
                        <div class="stars"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div>
                        <span class="category">Commercial</span>
                        <p class="review-text">"I've had the pleasure of insuring my businesses and properties with Hometown Insurance for many years..."</p>
                        <p class="author">K M</p>
                    </div>
                    <div class="review-card">
                        <div class="stars"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div>
                        <span class="category">Personal</span>
                        <p class="review-text">"I have been with Hometown Insurance Agency since 1979, when I bought my first car. ..."</p>
                        <p class="author">Mario Martins</p>
                    </div>
                    <div class="review-card">
                        <div class="stars"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div>
                        <span class="category">Personal</span>
                        <p class="review-text">"I couldn't be happier with the team at Hometown. They treat you like family!! Yesterday..."</p>
                        <p class="author">Laurie Kleinhenz</p>
                    </div>
                </div>
            </div>
            <div class="see-more-reviews"><a href="/testimonials">View full reviews and testimonials &rarr;</a></div>
        </div>
    </div>

    <!-- Insurance Built for You -->
    <section class="container" id="insurance-built" style="scroll-margin-top: 180px;">
        <div class="section-title">
            <h2>Insurance Built for You</h2>
            <p>At Hometown Insurance, we pride ourselves on being a <b>family-owned</b>, full-service agency. Whether you are looking for coverage for your family, your business, or your specialized professional needs, we provide a <b>comprehensive range of insurance solutions</b> tailored to every stage of life.</p>
        </div>
        <div class="product-row">
            <div class="product-img"><img src="https://static-asset.amac.us/wp-content/uploads/2026/02/05102523/home-1.jpg" alt="Personal Protection"></div>
            <div class="product-text">
                <span class="label" style="color: var(--personal-blue);">FOR INDIVIDUALS</span>
                <h2>Personal Protection</h2>
                <p>Protecting your home, family, and everything you've worked hard for — with the personal care it deserves.</p>
                <ul class="product-bullets">
                    <li>Homeowners & Renters Insurance</li>
                    <li>Auto & Motorcycle Insurance</li>
                    <li>Umbrella / Excess Liability</li>
                    <li>Flood & Earthquake Coverage</li>
                    <li>Valuable Items & Collections</li>
                    <li>Boat & Watercraft Insurance</li>
                </ul>
                <a href="/personal" class="btn btn-personal" style="margin-top: 20px;">Explore Personal Coverage</a>
            </div>
        </div>
        <div class="product-row">
            <div class="product-img"><img src="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?auto=format&fit=crop&w=800&q=80" alt="Business"></div>
            <div class="product-text">
                <span class="label" style="color: var(--success-green);">FOR BUSINESS</span>
                <h2>Business & Commercial</h2>
                <p>Building a business is a labor of love and a legacy for the future. We partner with you to safeguard your livelihood, your employees, and your reputation.</p>
                <a href="/business" class="btn btn-green">View Business Solutions</a>
            </div>
        </div>
        <div class="product-row">
            <div class="product-img"><img src="https://static-asset.amac.us/wp-content/uploads/2026/02/05102933/firefighters.jpg" alt="Firefighter & EMS Services"></div>
            <div class="product-text">
                <span class="label" style="color: var(--primary-red);">FOR THOSE WHO SERVE</span>
                <h2>Firefighter & EMS Services</h2>
                <p>To our local Fire, Police, and EMS professionals: you protect our families every single day, and it is our greatest honor to protect yours.</p>
                <a href="/firefighter-ems" class="btn btn-red">Explore Hero Programs</a>
            </div>
        </div>
        <div class="product-row">
            <div class="product-img"><img src="https://images.unsplash.com/photo-1576091160550-2173dba999ef?auto=format&fit=crop&w=800&q=80" alt="Life & Health"></div>
            <div class="product-text">
                <span class="label" style="color: var(--life-purple);">FOR PERSONAL SECURITY</span>
                <h2>Life & Health</h2>
                <p>Health and financial security provide the foundation for a peaceful retirement and a lasting legacy. We are here to guide you with expertise and commitment.</p>
                <a href="/life-health" class="btn btn-purple">Protect Your Future</a>
            </div>
        </div>
    </section>

    <!-- Carrier Bar -->
    <div class="carrier-bar">
        <div class="container">
            <h3>Our Trusted Insurance Partners</h3>
            <div class="logo-marquee-container">
                <div class="logo-marquee-track">
                    <img src="/images/logos/hartford.png" alt="The Hartford" class="carrier-logo">
                    <img src="/images/logos/travelers.png" alt="Travelers" class="carrier-logo">
                    <img src="/images/logos/progressive.png" alt="Progressive" class="carrier-logo">
                    <img src="/images/logos/metlife.png" alt="MetLife" class="carrier-logo">
                    <img src="/images/logos/chubb.png" alt="Chubb" class="carrier-logo">
                    <img src="/images/logos/liberty-mutual.png" alt="Liberty Mutual" class="carrier-logo">
                    <img src="/images/logos/hartford.png" alt="The Hartford" class="carrier-logo">
                    <img src="/images/logos/travelers.png" alt="Travelers" class="carrier-logo">
                    <img src="/images/logos/progressive.png" alt="Progressive" class="carrier-logo">
                    <img src="/images/logos/metlife.png" alt="MetLife" class="carrier-logo">
                    <img src="/images/logos/chubb.png" alt="Chubb" class="carrier-logo">
                    <img src="/images/logos/liberty-mutual.png" alt="Liberty Mutual" class="carrier-logo">
                </div>
            </div>
        </div>
    </div>

    <!-- Insurance Insights -->
    <div id="insights" class="insights-section">
        <div class="container">
            <div class="insights-header"><h2>Insurance Insights</h2><a href="/insights" class="read-more">View All Articles &rarr;</a></div>
            <div class="insights-grid">
                {recentPosts.map(post => {
                    const d = new Date(post.date);
                    const dateStr = d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }).toUpperCase();
                    return (
                        <div class="blog-card">
                            {post.image && (
                                <div class="blog-img" style={`background-image: url('${post.image}');`}></div>
                            )}
                            <div class="blog-content">
                                <span class="blog-date">{dateStr}</span>
                                <h3>{post.title}</h3>
                                <a href={`/insights/${post.slug}`} class="read-more">Read Full Article &rarr;</a>
                            </div>
                        </div>
                    );
                })}
            </div>
        </div>
    </div>

    <script is:inline>
        // Quote Modal
        const quoteModal = document.getElementById("quoteModal");
        const callbackOptions = document.getElementById("callbackOptions");
        const contactRadios = document.querySelectorAll('input[name="contact_method"]');
        const insuranceTypeSelect = document.getElementById("insuranceType");
        const otherInsuranceDiv = document.getElementById("otherInsuranceDiv");
        const otherInsuranceInput = document.getElementById("otherInsuranceInput");

        contactRadios.forEach(radio => {
            radio.addEventListener('change', () => {
                callbackOptions.style.display = ((radio).value === 'Callback') ? 'block' : 'none';
            });
        });

        insuranceTypeSelect?.addEventListener('change', function() {
            if (this.value === 'Other') {
                otherInsuranceDiv.style.display = 'block';
                otherInsuranceInput?.setAttribute('required', 'required');
            } else {
                otherInsuranceDiv.style.display = 'none';
                otherInsuranceInput?.removeAttribute('required');
            }
        });

        document.querySelectorAll(".openQuoteTrigger").forEach(btn => {
            btn.addEventListener('click', (e) => { e.preventDefault(); quoteModal.style.display = "flex"; });
        });
        document.getElementById("closeQuoteModal").onclick = () => quoteModal.style.display = "none";
        window.addEventListener('click', (event) => {
            if (event.target === quoteModal) quoteModal.style.display = "none";
        });

        // Carousel
        let currentSlide = 0;
        const slides = document.querySelectorAll('.carousel-slide');
        function showSlide(index) {
            slides[currentSlide]?.classList.remove('active');
            currentSlide = (index + slides.length) % slides.length;
            slides[currentSlide]?.classList.add('active');
        }
        function showNextSlide() { showSlide(currentSlide + 1); }
        function showPrevSlide() { showSlide(currentSlide - 1); }
        let slideInterval = setInterval(showNextSlide, 4000);
        function resetInterval() { clearInterval(slideInterval); slideInterval = setInterval(showNextSlide, 4000); }
        document.getElementById('nextSlide').onclick = () => { showNextSlide(); resetInterval(); };
        document.getElementById('prevSlide').onclick = () => { showPrevSlide(); resetInterval(); };

        document.getElementById('quoteForm').onsubmit = (e) => {
            e.preventDefault();
            alert("Thank you! Your quote request has been sent to the Hometown team.");
            quoteModal.style.display = "none";
        };
    </script>

<style>
    .carrier-logo {
        height: 180px !important;
        width: 280px !important;
        margin-right: 60px !important;
        flex-shrink: 0;
        object-fit: contain !important;
    }
    .product-bullets {
        list-style: none !important;
        padding: 0 !important;
        margin: 15px 0 !important;
        display: grid !important;
        grid-template-columns: 1fr 1fr !important;
        gap: 8px 20px !important;
    }
    .product-bullets li {
        font-size: 15px !important;
        color: #4b5563 !important;
        padding-left: 24px !important;
        position: relative !important;
        line-height: 1.4 !important;
    }
    .product-bullets li::before {
        content: "✓" !important;
        position: absolute !important;
        left: 0 !important;
        top: 50% !important;
        transform: translateY(-50%) !important;
        width: 16px !important;
        height: 16px !important;
        background: var(--personal-blue) !important;
        color: #fff !important;
        border-radius: 50% !important;
        font-size: 10px !important;
        font-weight: bold !important;
        line-height: 16px !important;
        text-align: center !important;
    }
    @media (max-width: 768px) {
        .product-bullets { grid-template-columns: 1fr !important; }
    }
</style>
</BaseLayout>
