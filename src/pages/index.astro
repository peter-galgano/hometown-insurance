                    <img src="/images/logos/travelers.png" alt="Travelers" class="carrier-logo">
                    <img src="/images/logos/progressive.png" alt="Progressive" class="carrier-logo">
                    <img src="/images/logos/metlife.png" alt="MetLife" class="carrier-logo">
                    <img src="/images/logos/chubb.png" alt="Chubb" class="carrier-logo">
                    <img src="/images/logos/liberty-mutual.png" alt="Liberty Mutual" class="carrier-logo">
                    <img src="/images/logos/hartford.png" alt="The Hartford" class="carrier-logo">
                    <img src="/images/logos/travelers.png" alt="Travelers" class="carrier-logo">
                    <img src="/images/logos/progressive.png" alt="Progressive" class="carrier-logo">
                    <img src="/images/logos/metlife.png" alt="MetLife" class="carrier-logo">
                    <img src="/images/logos/chubb.png" alt="Chubb" class="carrier-logo">
                    <img src="/images/logos/liberty-mutual.png" alt="Liberty Mutual" class="carrier-logo">
                </div>
            </div>
        </div>
    </div>

    <!-- Insurance Insights -->
    <div id="insights" class="insights-section">
        <div class="container">
            <div class="insights-header"><h2>Insurance Insights</h2><a href="/insights" class="read-more">View All Articles &rarr;</a></div>
            <div class="insights-grid">
                {recentPosts.map(post => {
                    const d = new Date(post.date);
                    const dateStr = d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }).toUpperCase();
                    return (
                        <div class="blog-card">
                            {post.image && (
                                <div class="blog-img" style={`background-image: url('${post.image}');`}></div>
                            )}
                            <div class="blog-content">
                                <span class="blog-date">{dateStr}</span>
                                <h3>{post.title}</h3>
                                <a href={`/insights/${post.slug}`} class="read-more">Read Full Article &rarr;</a>
                            </div>
                        </div>
                    );
                })}
            </div>
        </div>
    </div>

    <script is:inline>
        // Carousel
        var currentSlide = 0;
        var slides = document.querySelectorAll('.carousel-slide');
        function showSlide(index) {
            if (slides[currentSlide]) slides[currentSlide].classList.remove('active');
            currentSlide = (index + slides.length) % slides.length;
            if (slides[currentSlide]) slides[currentSlide].classList.add('active');
        }
        function showNextSlide() { showSlide(currentSlide + 1); }
        function showPrevSlide() { showSlide(currentSlide - 1); }
        var slideInterval = setInterval(showNextSlide, 4000);
        function resetInterval() { clearInterval(slideInterval); slideInterval = setInterval(showNextSlide, 4000); }
        document.getElementById('nextSlide').onclick = function() { showNextSlide(); resetInterval(); };
        document.getElementById('prevSlide').onclick = function() { showPrevSlide(); resetInterval(); };

        // Homepage Quote Form Handling
        var homeInsuranceType = document.getElementById('homeInsuranceType');
        var homeOtherInsuranceDiv = document.getElementById('homeOtherInsuranceDiv');
        var homeOtherInsuranceInput = document.getElementById('homeOtherInsuranceInput');
        var homeCallbackOptions = document.getElementById('homeCallbackOptions');
        var homeHearAbout = document.getElementById('homeHearAbout');
        var homeHearOtherDiv = document.getElementById('homeHearOtherDiv');
        var homeHearOtherInput = document.getElementById('homeHearOtherInput');

        // Insurance type "Other" toggle
        if (homeInsuranceType) {
            homeInsuranceType.addEventListener('change', function() {
                if (this.value === 'Other') {
                    homeOtherInsuranceDiv.style.display = 'block';
                    if (homeOtherInsuranceInput) homeOtherInsuranceInput.setAttribute('required', 'required');
                } else {
                    homeOtherInsuranceDiv.style.display = 'none';
                    if (homeOtherInsuranceInput) homeOtherInsuranceInput.removeAttribute('required');
                }
            });
        }

        // Contact method toggle
        document.querySelectorAll('input[name="contact_method"]').forEach(function(radio) {
            radio.addEventListener('change', function() {
                if (homeCallbackOptions) homeCallbackOptions.style.display = radio.value === 'Callback' ? 'block' : 'none';
            });
        });

        // Hear about "Other" toggle
        if (homeHearAbout) {
            homeHearAbout.addEventListener('change', function() {
                if (this.value === 'Other') {
                    homeHearOtherDiv.style.display = 'block';
                    if (homeHearOtherInput) homeHearOtherInput.setAttribute('required', 'required');
                } else {
                    homeHearOtherDiv.style.display = 'none';
                    if (homeHearOtherInput) homeHearOtherInput.removeAttribute('required');
                }
            });
        }

        // Toast notification
        function showToast(message, type) {
            var existing = document.getElementById('sigToast');
            if (existing) existing.remove();

            var toast = document.createElement('div');
            toast.id = 'sigToast';
            toast.textContent = message;
            toast.style.cssText = 'position:fixed;top:30px;left:50%;transform:translateX(-50%);z-index:100000;padding:16px 28px;border-radius:10px;font-weight:700;font-size:16px;box-shadow:0 4px 20px rgba(0,0,0,0.2);opacity:0;transition:opacity 0.3s ease;max-width:90%;text-align:center;';
            toast.style.background = type === 'success' ? '#10b981' : '#ef4444';
            toast.style.color = '#fff';
            document.body.appendChild(toast);

            // Fade in
            setTimeout(function() { toast.style.opacity = '1'; }, 10);

            // Fade out and remove after 4 seconds
            setTimeout(function() {
                toast.style.opacity = '0';
                setTimeout(function() { toast.remove(); }, 300);
            }, 4000);
        }

        // Form submit
        var homeQuoteForm = document.getElementById('homeQuoteForm');
        var homeQuoteFormMsg = document.getElementById('homeQuoteFormMsg');
        if (homeQuoteForm) {
            homeQuoteForm.addEventListener('submit', function(e) {
                e.preventDefault();

                var submitBtn = homeQuoteForm.querySelector('button[type="submit"]');
                var originalBtnText = submitBtn.textContent;

                // Show sending state
                submitBtn.textContent = 'Sending...';
                submitBtn.disabled = true;
                if (homeQuoteFormMsg) homeQuoteFormMsg.style.display = 'none';

                // Collect form data
                var formData = {
                    full_name: homeQuoteForm.querySelector('input[name="full_name"]').value,
                    email: homeQuoteForm.querySelector('input[name="email"]').value,
                    phone: homeQuoteForm.querySelector('input[name="phone"]').value,
                    insurance_type: homeQuoteForm.querySelector('select[name="insurance_type"]').value,
                    other_insurance: homeQuoteForm.querySelector('input[name="other_insurance"]') ? homeQuoteForm.querySelector('input[name="other_insurance"]').value : '',
                    contact_method: homeQuoteForm.querySelector('input[name="contact_method"]:checked').value,
                    callback_day: homeQuoteForm.querySelector('select[name="callback_day"]') ? homeQuoteForm.querySelector('select[name="callback_day"]').value : '',
                    callback_time: homeQuoteForm.querySelector('select[name="callback_time"]') ? homeQuoteForm.querySelector('select[name="callback_time"]').value : '',
                    hear_about: homeQuoteForm.querySelector('select[name="hear_about"]').value,
                    hear_other: homeQuoteForm.querySelector('input[name="hear_other"]') ? homeQuoteForm.querySelector('input[name="hear_other"]').value : '',
                    promo_code: homeQuoteForm.querySelector('input[name="promo_code"]').value,
                    message: homeQuoteForm.querySelector('textarea[name="message"]').value,
                    page: 'homepage'
                };

                // Submit to API
                fetch('/api/lead', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(formData)
                })
                .then(function(response) { return response.json(); })
                .then(function(data) {
                    if (data.success) {
                        homeQuoteForm.reset();
                        var quoteModal = document.getElementById('quoteModal');
                        if (quoteModal) { quoteModal.style.display = "none"; }
                        showToast('✓ Your request has been sent! Our team will be in touch shortly.', 'success');
                    } else {
                        showToast(data.error || 'Something went wrong. Please try again.', 'error');
                    }
                })
                .catch(function() {
                    showToast('Network error. Please try again.', 'error');
                })
                .finally(function() {
                    submitBtn.textContent = originalBtnText;
                    submitBtn.disabled = false;
                });
            });
        }
    </script>

