---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Hometown Insurance Agency - Protecting what matters most since 1979.' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description}>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <!-- Google Tag Manager -->
    <script is:inline>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer','GTM-TQ96BMZH');
    </script>
    <!-- End Google Tag Manager -->
</head>
<body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-TQ96BMZH"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->

    <!-- Quote Modal -->
    <div class="modal-overlay" id="quoteModal">
        <div class="modal-content quote-form-modal">
            <span class="close-modal" id="closeQuoteModal">&times;</span>
            <div class="form-header">
                <h2>Get Your Personal Quote</h2>
                <p>Tell us a bit about your needs and we'll handle the rest.</p>
            </div>
            <form id="quoteForm">
                <div class="form-group"><label>Full Name <span class="req">*</span></label><input type="text" name="full_name" placeholder="John Doe" required></div>
                <div class="form-row">
                    <div class="form-group"><label>Email Address <span class="req">*</span></label><input type="email" name="email" placeholder="john@example.com" required></div>
                    <div class="form-group"><label>Phone Number <span class="req">*</span></label><input type="tel" name="phone" placeholder="631-555-0100" required></div>
                </div>
                <div class="form-group">
                    <label>Insurance type? <span class="req">*</span></label>
                    <select id="modalInsuranceType" name="insurance_type" required>
                        <option value="" disabled selected>Select an option...</option>
                        <option>Personal Protection (Home/Auto)</option>
                        <option>Business & Commercial</option>
                        <option>Firefighter & EMS Services</option>
                        <option>Life & Health</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
                <div class="form-group other-details-box" id="modalOtherDiv" style="display: none;">
                    <label>Please specify insurance type: <span class="req">*</span></label>
                    <input type="text" id="modalOtherInput" name="other_insurance" placeholder="Enter coverage type..." required>
                </div>
                <div class="form-group">
                    <label>Preferred way for us to reach you? <span class="req">*</span></label>
                    <div class="radio-group">
                        <label class="radio-label"><input type="radio" name="modal_contact_method" value="Email" checked> Email</label>
                        <label class="radio-label"><input type="radio" name="modal_contact_method" value="Callback"> Give me a callback</label>
                    </div>
                </div>
                <div id="modalCallbackOptions" style="display: none; border-top: 1px solid #eee; padding-top: 15px; margin-top: 5px;">
                    <div class="form-row">
                        <div class="form-group"><label>Preferred Day <span class="req">*</span></label><select name="callback_day" required><option>Monday</option><option>Tuesday</option><option>Wednesday</option><option>Thursday</option><option>Friday</option></select></div>
                        <div class="form-group"><label>Preferred Time <span class="req">*</span></label><select name="callback_time" required><option>Morning (9am - 12pm)</option><option>Afternoon (12pm - 5pm)</option><option>Evening (After 5pm)</option></select></div>
                    </div>
                </div>
                <div class="form-group">
                    <label>How did you hear about us? <span class="req">*</span></label>
                    <select id="modalHearAbout" name="hear_about" required>
                        <option value="" disabled selected>Please select...</option>
                        <option>Google Search</option>
                        <option>Facebook / Instagram</option>
                        <option>Friend or Family Member</option>
                        <option>Mailing / Flyer</option>
                        <option>Local Event</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
                <div class="form-group other-details-box" id="modalHearOtherDiv" style="display: none;">
                    <label>Please specify how you heard about us: <span class="req">*</span></label>
                    <input type="text" id="modalHearOtherInput" name="hear_other" placeholder="Tell us how you found us...">
                </div>
                <div class="form-group">
                    <label>Promo Code (if any)</label>
                    <input type="text" name="promo_code" placeholder="Enter promo code">
                </div>
                <div class="form-group">
                    <label>Add a message (optional)</label>
                    <textarea name="message" rows="2" placeholder="Tell us more about your specific needs..."></textarea>
                </div>
                <button type="submit" class="btn btn-red btn-pulse" style="width: 100%; margin-top: 10px;">Send Quote Request</button>
            </form>
            <p id="quoteFormMsg" style="display:none; margin-top:10px; font-weight:700; text-align:center;"></p>
        </div>
    </div>

    <div class="modal-overlay" id="mapModal">
        <div class="modal-content">
            <span class="close-modal" id="closeMapModal">&times;</span>
            <h2 style="text-align: center; margin-bottom: 20px; color: var(--dark-blue); font-size: 38px;">Hometown Insurance Agency</h2>
            <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3023.633908226066!2d-73.11183182342502!3d40.72608403675005!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e8334465d637c3%3A0xc665135f606822c6!2s5%20Orville%20Dr%2C%20Bohemia%2C%20NY%2011716!5e0!3m2!1sen!2sus!4v1700000000000!5m2!1sen!2sus" width="100%" height="450" style="border:0; border-radius: 8px;" allowfullscreen="" loading="lazy"></iframe>
        </div>
    </div>

    <div class="nav-overlay" id="navOverlay" onclick="document.getElementById('hamburgerBtn').classList.remove('active'); document.getElementById('mobileNavPanel').classList.remove('open'); document.body.classList.remove('nav-open');"></div>
    <div class="mobile-nav-panel" id="mobileNavPanel">
        <span class="mobile-nav-close" onclick="document.getElementById('mobileNavPanel').classList.remove('open'); document.getElementById('hamburgerBtn').classList.remove('active'); document.body.classList.remove('nav-open');">&times;</span>
        <ul class="mobile-nav-list">
            <li>
                <a href="#" class="mobile-dropdown-toggle" onclick="event.preventDefault(); event.stopPropagation(); var sub=this.nextElementSibling; sub.style.display=sub.style.display==='block'?'none':'block'; this.classList.toggle('open');">Products & Services <small>▼</small></a>
                <ul class="mobile-dropdown-sub">
                    <li><a href="/personal">Personal Protection</a></li>
                    <li><a href="/business">Business & Commercial</a></li>
                    <li><a href="/firefighter-ems">Firefighter & EMS Services</a></li>
                    <li><a href="/life-health">Life & Health</a></li>
                </ul>
            </li>
            <li><a href="/about">About</a></li>
            <li><a href="/insights">Insights</a></li>
            <li><a href="/faqs">FAQs</a></li>
            <li><a href="/contact">Contact Us</a></li>
            <li><a href="/claims">Claims Center</a></li>
        </ul>
    </div>
    <div class="sticky-header">
        <div class="top-info">
            <div class="container prominent-contact-flex">
                <div class="contact-prominent">
                    <div class="contact-item openMapTrigger">
                        <i class="fa-solid fa-location-dot"></i>
                        <span><b>Find Us:</b> 5 Orville Drive, Suite 400, Bohemia, NY 11716</span>
                    </div>
                    <div class="contact-item">
                        <i class="fa-solid fa-phone-volume"></i>
                        <span><b>Call Us:</b> <a href="tel:6315890100">631-589-0100</a></span>
                    </div>
                </div>
                <div class="top-socials social-icons-shared">
                    <a href="https://www.facebook.com/HometownInsurance/" target="_blank"><i class="fab fa-facebook-f"></i></a>
                    <a href="https://www.youtube.com/@hometowninsuranceagencyofLI/featured" target="_blank"><i class="fab fa-youtube"></i></a>
                    <a href="https://www.instagram.com/hometown_insurance_agency_li/" target="_blank"><i class="fab fa-instagram"></i></a>
                    <a href="https://www.linkedin.com/company/hometown-insurance-agency-of-li" target="_blank"><i class="fab fa-linkedin-in"></i></a>
                </div>
            </div>
        </div>
        <header class="main-header">
            <div class="container">
                <nav class="main-nav">
                    <a href="/" class="logo"><img src="https://static-asset.amac.us/wp-content/uploads/2026/02/04173133/hometown-header-logo2.png" alt="Hometown Insurance"></a>
                    <ul class="nav-links" id="navLinks">
                        <li>
                            <a href="#" class="has-dropdown">Products & Services <small>▼</small></a>
                            <ul class="dropdown-menu">
                                <li><a href="/personal">Personal Protection</a></li>
                                <li><a href="/business">Business & Commercial</a></li>
                                <li><a href="/firefighter-ems">Firefighter & EMS Services</a></li>
                                <li><a href="/life-health">Life & Health</a></li>
                            </ul>
                        </li>
                        <li><a href="/about">About</a></li>
                        <li><a href="/insights">Insights</a></li>
                        <li><a href="/faqs">FAQs</a></li>
                        <li><a href="/contact">Contact Us</a></li>
                        <li class="mobile-nav-btns">
                            <a href="#" class="btn btn-red btn-pulse openQuoteTrigger">Get a Quote</a>
                        </li>
                    </ul>
                    <div class="nav-btns">
                        <a href="/claims" class="btn btn-white">Claims</a>
                        <slot name="quote-button">
                            <a href="#" class="btn btn-red btn-pulse openQuoteTrigger">Get a Quote</a>
                        </slot>
                    </div>
                    <div class="mobile-nav-btns-header">
                        <a href="/claims" class="btn btn-white">Claims</a>
                        <a href="#" class="btn btn-red btn-pulse openQuoteTrigger">Get a Quote</a>
                    </div>
                    <button class="hamburger" id="hamburgerBtn" aria-label="Toggle menu" onclick="this.classList.toggle('active'); document.getElementById('mobileNavPanel').classList.toggle('open'); document.body.classList.toggle('nav-open');" style="z-index: 3012; position: relative;">
                        <span></span><span></span><span></span>
                    </button>
                </nav>
            </div>
        </header>
    </div>

    <slot />

    <footer class="new-footer">
        <div class="container">
            <div class="newsletter">
                <div class="newsletter-text">
                    <h2>Hometown Monthly Newsletter</h2>
                    <p>Insurance insights and safety tips delivered right to your inbox.</p>
                </div>
                <div class="newsletter-form-wrap">
                    <form class="newsletter-form" id="newsletterForm">
                        <input type="email" id="newsletterEmail" placeholder="Your email address" required>
                        <button type="submit" class="btn btn-red" id="newsletterBtn">Subscribe Now</button>
                    </form>
                    <p id="newsletterMsg" style="display:none; margin-top:10px; font-weight:700;"></p>
                </div>
            </div>

            <div class="footer-grid">
                <div class="footer-col footer-logo-area">
                    <img src="https://static-asset.amac.us/wp-content/uploads/2026/02/04174156/hometown-header-logo-white.png" alt="Hometown Insurance">
                    <p>Protecting what matters most since 1979.</p>
                    <div class="social-icons-shared" style="margin-top: 20px; text-align: left;">
                        <a href="https://www.facebook.com/HometownInsurance/" target="_blank" style="margin-left: 0;"><i class="fab fa-facebook-f"></i></a>
                        <a href="https://www.youtube.com/@hometowninsuranceagencyofLI/featured" target="_blank"><i class="fab fa-youtube"></i></a>
                        <a href="https://www.instagram.com/hometown_insurance_agency_li/" target="_blank"><i class="fab fa-instagram"></i></a>
                        <a href="https://www.linkedin.com/company/hometown-insurance-agency-of-li" target="_blank"><i class="fab fa-linkedin-in"></i></a>
                    </div>
                </div>
                <div class="footer-col">
                    <h3>Products & Services</h3>
                    <ul class="footer-links">
                        <li><a href="/personal">Personal Protection</a></li>
                        <li><a href="/business">Business & Commercial</a></li>
                        <li><a href="/firefighter-ems">Firefighter & EMS Services</a></li>
                        <li><a href="/life-health">Life & Health</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h3>Quick Links</h3>
                    <ul class="footer-links">
                        <li><a href="/about">About</a></li>
                        <li><a href="/insights">Insurance Insights</a></li>
                        <li><a href="/testimonials">Reviews/Testimonials</a></li>
                        <li><a href="/claims">Claims Center</a></li>
                    </ul>
                </div>
                <div class="footer-col footer-contact">
                    <h3>Contact Us</h3>
                    <p class="openMapTrigger" style="cursor:pointer;"><i class="fa-solid fa-location-dot"></i> 5 Orville Drive, Suite 400, Bohemia, NY 11716</p>
                    <p><i class="fa-solid fa-phone"></i> <a href="tel:6315890100">631-589-0100</a></p>
                    <p><i class="fa-solid fa-envelope"></i> <a href="mailto:service@hometowninsurance.com">service@hometowninsurance.com</a></p>
                </div>
            </div>
        </div>
        <div class="footer-bottom"><div class="container"><p>&copy; 2026 Hometown Insurance Agency.</p></div></div>
    </footer>

    <script is:inline>
        // Phone number formatting: (631) 555-0100
        function formatPhone(input) {
            var digits = input.value.replace(/\D/g, '');
            if (digits.length > 10) digits = digits.substring(0, 10);
            var formatted = '';
            if (digits.length > 0) formatted = '(' + digits.substring(0, 3);
            if (digits.length >= 3) formatted += ') ';
            if (digits.length > 3) formatted += digits.substring(3, 6);
            if (digits.length > 6) formatted += '-' + digits.substring(6, 10);
            input.value = formatted;
        }
        document.querySelectorAll('input[type="tel"]').forEach(function(input) {
            input.addEventListener('input', function() { formatPhone(input); });
            input.setAttribute('placeholder', '(631) 555-0100');
            input.setAttribute('maxlength', '14');
        });

        // Map Modal
        var mapModal = document.getElementById("mapModal");
        document.querySelectorAll(".openMapTrigger").forEach(function(btn) {
            btn.onclick = function() { mapModal.style.display = "flex"; };
        });
        document.getElementById("closeMapModal").onclick = function() { mapModal.style.display = "none"; };

        // Quote Modal
        var quoteModal = document.getElementById("quoteModal");
        var modalCallbackOptions = document.getElementById("modalCallbackOptions");
        var modalInsuranceType = document.getElementById("modalInsuranceType");
        var modalOtherDiv = document.getElementById("modalOtherDiv");
        var modalOtherInput = document.getElementById("modalOtherInput");

        document.querySelectorAll(".openQuoteTrigger").forEach(function(btn) {
            btn.addEventListener('click', function(e) { e.preventDefault(); quoteModal.style.display = "flex"; });
        });
        document.getElementById("closeQuoteModal").onclick = function() { quoteModal.style.display = "none"; };

        // Quote modal - insurance type "Other" toggle
        if (modalInsuranceType) {
            modalInsuranceType.addEventListener('change', function() {
                if (this.value === 'Other') {
                    modalOtherDiv.style.display = 'block';
                    if (modalOtherInput) modalOtherInput.setAttribute('required', 'required');
                } else {
                    modalOtherDiv.style.display = 'none';
                    if (modalOtherInput) modalOtherInput.removeAttribute('required');
                }
            });
        }

        // Quote modal - contact method toggle
        document.querySelectorAll('input[name="modal_contact_method"]').forEach(function(radio) {
            radio.addEventListener('change', function() {
                modalCallbackOptions.style.display = radio.value === 'Callback' ? 'block' : 'none';
            });
        });

        // Quote modal - hear about toggle
        var modalHearAbout = document.getElementById("modalHearAbout");
        var modalHearOtherDiv = document.getElementById("modalHearOtherDiv");
        var modalHearOtherInput = document.getElementById("modalHearOtherInput");
        if (modalHearAbout) {
            modalHearAbout.addEventListener('change', function() {
                if (this.value === 'Other') {
                    modalHearOtherDiv.style.display = 'block';
                    if (modalHearOtherInput) modalHearOtherInput.setAttribute('required', 'required');
                } else {
                    modalHearOtherDiv.style.display = 'none';
                    if (modalHearOtherInput) modalHearOtherInput.removeAttribute('required');
                }
            });
        }

        // Toast notification
        function showToast(message, type) {
            var existing = document.getElementById('sigToast');
            if (existing) existing.remove();

            var toast = document.createElement('div');
            toast.id = 'sigToast';
            toast.textContent = message;
            toast.style.cssText = 'position:fixed;top:30px;left:50%;transform:translateX(-50%);z-index:100000;padding:16px 28px;border-radius:10px;font-weight:700;font-size:16px;box-shadow:0 4px 20px rgba(0,0,0,0.2);opacity:0;transition:opacity 0.3s ease;max-width:90%;text-align:center;';
            toast.style.background = type === 'success' ? '#10b981' : '#ef4444';
            toast.style.color = '#fff';
            document.body.appendChild(toast);
            setTimeout(function() { toast.style.opacity = '1'; }, 10);
            setTimeout(function() {
                toast.style.opacity = '0';
                setTimeout(function() { toast.remove(); }, 300);
            }, 4000);
        }

        // Quote modal - form submit
        var quoteForm = document.getElementById('quoteForm');
        var quoteFormMsg = document.getElementById('quoteFormMsg');
        if (quoteForm) {
            quoteForm.addEventListener('submit', function(e) {
                e.preventDefault();

                var submitBtn = quoteForm.querySelector('button[type="submit"]');
                var originalBtnText = submitBtn.textContent;

                // Show sending state
                submitBtn.textContent = 'Sending...';
                submitBtn.disabled = true;
                if (quoteFormMsg) quoteFormMsg.style.display = 'none';

                // Collect form data (defensive — use helper to avoid null errors)
                function gv(form, sel) { var el = form.querySelector(sel); return el ? el.value : ''; }
                var checkedRadio = quoteForm.querySelector('input[name="modal_contact_method"]:checked');
                var formData = {
                    full_name: gv(quoteForm, 'input[name="full_name"]'),
                    email: gv(quoteForm, 'input[name="email"]'),
                    phone: gv(quoteForm, 'input[name="phone"]'),
                    insurance_type: gv(quoteForm, 'select[name="insurance_type"]'),
                    other_insurance: gv(quoteForm, 'input[name="other_insurance"]'),
                    contact_method: checkedRadio ? checkedRadio.value : 'Email',
                    callback_day: gv(quoteForm, 'select[name="callback_day"]'),
                    callback_time: gv(quoteForm, 'select[name="callback_time"]'),
                    hear_about: gv(quoteForm, 'select[name="hear_about"]'),
                    hear_other: gv(quoteForm, 'input[name="hear_other"]'),
                    promo_code: gv(quoteForm, 'input[name="promo_code"]'),
                    message: gv(quoteForm, 'textarea[name="message"]'),
                    page: 'quote-modal'
                };

                // Submit to API
                fetch('/api/lead', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(formData)
                })
                .then(function(response) { return response.json(); })
                .then(function(data) {
                    if (data.success) {
                        window.dataLayer = window.dataLayer || [];
                        window.dataLayer.push({
                            event: 'form_submission',
                            form_name: formData.page,
                            insurance_type: formData.insurance_type || '',
                            contact_method: formData.contact_method || '',
                            hear_about: formData.hear_about || '',
                            help_type: ''
                        });
                        quoteForm.reset();
                        quoteModal.style.display = "none";
                        showToast('✓ Your request has been sent! Our team will be in touch shortly.', 'success');
                    } else {
                        showToast(data.error || 'Something went wrong. Please try again.', 'error');
                    }
                })
                .catch(function() {
                    showToast('Network error. Please try again.', 'error');
                })
                .finally(function() {
                    submitBtn.textContent = originalBtnText;
                    submitBtn.disabled = false;
                });
            });
        }

        // Close modals on overlay click
        window.addEventListener('click', function(event) {
            if (event.target === mapModal) mapModal.style.display = "none";
            if (event.target === quoteModal) quoteModal.style.display = "none";
        });

        // Hamburger Menu
        var hamburgerBtn = document.getElementById('hamburgerBtn');
        var navLinks = document.getElementById('navLinks');
        var body = document.body;

        // Mobile nav panel dropdown toggle
        var mobilePanel = document.getElementById('mobileNavPanel');
        if (mobilePanel) {
            mobilePanel.querySelectorAll('.mobile-dropdown-toggle').forEach(function(toggle) {
                toggle.addEventListener('click', function(e) {
                    e.preventDefault();
                    var sub = toggle.nextElementSibling;
                    if (sub) {
                        sub.style.display = sub.style.display === 'block' ? 'none' : 'block';
                    }
                });
            });
            // Close panel when clicking a nav link (not the dropdown toggle)
            mobilePanel.querySelectorAll('a:not(.mobile-dropdown-toggle)').forEach(function(link) {
                link.addEventListener('click', function() {
                    mobilePanel.classList.remove('open');
                    hamburgerBtn.classList.remove('active');
                    body.classList.remove('nav-open');
                });
            });
        }

        // Close mobile nav on resize to desktop
        window.addEventListener('resize', function() {
            if (window.innerWidth > 1200) {
                hamburgerBtn.classList.remove('active');
                if (mobilePanel) mobilePanel.classList.remove('open');
                body.classList.remove('nav-open');
            }
        });

        // Newsletter signup
        var nlForm = document.getElementById('newsletterForm');
        if (nlForm) {
            nlForm.addEventListener('submit', function(e) {
                e.preventDefault();
                var email = document.getElementById('newsletterEmail').value;
                var btn = document.getElementById('newsletterBtn');
                var msg = document.getElementById('newsletterMsg');
                btn.disabled = true;
                btn.textContent = 'Subscribing...';
                msg.style.display = 'none';

                fetch('/api/newsletter', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: email })
                })
                .then(function(res) { return res.json(); })
                .then(function(data) {
                    msg.style.display = 'block';
                    if (data.success) {
                        msg.style.color = '#22c55e';
                        msg.textContent = '✓ You\'re subscribed! Thank you.';
                        document.getElementById('newsletterEmail').value = '';
                    } else {
                        msg.style.color = '#ef4444';
                        msg.textContent = data.error || 'Something went wrong. Please try again.';
                    }
                    btn.disabled = false;
                    btn.textContent = 'Subscribe Now';
                })
                .catch(function() {
                    msg.style.display = 'block';
                    msg.style.color = '#ef4444';
                    msg.textContent = 'Unable to subscribe right now. Please try again later.';
                    btn.disabled = false;
                    btn.textContent = 'Subscribe Now';
                });
            });
        }
    </script>
</body>
</html>
